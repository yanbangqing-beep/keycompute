# =============================================================================
# .dockerignore — Docker 构建上下文过滤
#
# 排除无关文件，减小构建上下文体积，加速 docker build 上传速度
# =============================================================================

# ── Rust 编译产物（最大的目录，必须排除）──
target/

# ── Git 历史与元数据 ──
.git/
.gitignore

# ── 前端构建产物（由 Docker 内部编译生成）──
packages/web/dist/
packages/desktop/dist/
packages/mobile/dist/

# ── 环境变量文件（包含敏感密钥，严禁进入构建上下文）──
.env
.env.*
!.env.example

# ── 开发工具配置（不影响构建结果）──
.qoder/
.vscode/
.idea/
*.iml
.codex
.claude

# ── 文档与说明文件 ──
*.md
!README.md
LICENSE
docs/__pycache__/

# ── 测试文件（生产镜像不需要，但 Cargo workspace 解析需要目录存在，只排除源码）──
# 注意：不能排除整个 crates/integration-tests/ 目录
# 因为根 Cargo.toml workspace.members 声明了它，cargo chef prepare/build 会因找不到成员目录而失败
# crates/integration-tests/

# ── CI/CD 配置 ──
.github/

# ── 临时与日志文件 ──
*.log
*.tmp
*.bak
*.swp

# ── macOS 系统文件 ──
.DS_Store
AGENTS.md